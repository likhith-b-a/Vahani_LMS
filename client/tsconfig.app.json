{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "noEmit": true,

    "types": ["vite/client"],
    "skipLibCheck": true,

    /* ✅ ALIAS FIX */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* ✅ RELAXED SETTINGS */
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    /* ✅ SAFE INTEROP */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },

  "include": ["src"],

  "exclude": [
    "node_modules",
    "dist",
    "src/test",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}